# Database
DATABASE_URL="postgresql://jobpilot:jobpilot@localhost:5432/jobpilot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Application
NODE_ENV="development"
LOG_LEVEL="info"

# Rate Limiting
MAX_DAILY_APPLICATIONS=100
RATE_LIMIT_MS=30000

# Server
PORT=3000
HOST="0.0.0.0"

# LinkedIn (optional — needed for LinkedIn scraper)
# Export cookies as JSON array from a logged-in LinkedIn session
LINKEDIN_COOKIE_PATH=
