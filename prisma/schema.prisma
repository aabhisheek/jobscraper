generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id           String        @id @default(cuid())
  title        String
  company      String
  location     String
  description  String
  skills       String[]
  experience   String?
  salary       String?
  applyLink    String        @unique
  applyType    String
  source       String
  sourceId     String
  status       String        @default("scraped")
  score        Int?
  dateScraped  DateTime      @default(now())
  applications Application[]

  @@unique([source, sourceId])
  @@index([source])
  @@index([status])
  @@index([score])
}

model Application {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id])
  status      String    @default("not_applied")
  dateApplied DateTime?
  resumeUsed  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([jobId])
}

model Company {
  id         String   @id @default(cuid())
  name       String   @unique
  careerPage String?
  techStack  String[]
}
